    {
      "cell_type": "markdown",
      "source": [
        "##treino"
      ],
      "metadata": {
        "id": "NH7QGKobb1FY"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "\n",
        "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "from tensorflow.keras.models import Sequential, clone_model\n",
        "from tensorflow.keras.layers import Dense"
      ],
      "metadata": {
        "id": "DdqYE70DcWgP"
      },
      "execution_count": 23,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def f1(x):\n",
        "    return 0.5*x + 0.3 + np.random.uniform(-0.1, 0.1, size=x.shape)"
      ],
      "metadata": {
        "id": "wq6-7QKrcbQO"
      },
      "execution_count": 24,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def f2(x):\n",
        "    return 0.5*x**2 - 0.3*x + 0.8 + np.random.uniform(-0.1, 0.1, size=x.shape)\n"
      ],
      "metadata": {
        "id": "rdJaQdd_ceXY"
      },
      "execution_count": 25,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def gerar_dataset(n, func):\n",
        "    x = np.random.uniform(0, 1, n)\n",
        "    y = func(x)\n",
        "    return x.reshape(-1,1), y.reshape(-1,1)\n",
        "\n",
        "\n",
        "size = [2,5,10,20,30,40,50,100,150,200,300,400,500]"
      ],
      "metadata": {
        "id": "SSBKJPf3cg7L"
      },
      "execution_count": 26,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "##modelo:"
      ],
      "metadata": {
        "id": "v6cWccBDcoWc"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def modelo_A():\n",
        "    model = Sequential([\n",
        "        Dense(1, input_dim=1, activation='linear')\n",
        "    ])\n",
        "    model.compile(optimizer='sgd', loss='mse')\n",
        "    return model"
      ],
      "metadata": {
        "id": "_ULnY9cPcn3m"
      },
      "execution_count": 27,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def modelo_B():\n",
        "    model = Sequential([\n",
        "        Dense(2, input_dim=1, activation='linear'),\n",
        "        Dense(1, activation='linear')\n",
        "    ])\n",
        "    model.compile(optimizer='sgd', loss='mse')\n",
        "    return model"
      ],
      "metadata": {
        "id": "VSw_DHtBcxGx"
      },
      "execution_count": 28,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def modelo_C():\n",
        "    model = Sequential([\n",
        "        Dense(30, input_dim=1, activation='linear'),\n",
        "        Dense(1, activation='linear')\n",
        "    ])\n",
        "    model.compile(optimizer='sgd', loss='mse')\n",
        "    return model\n",
        "\n"
      ],
      "metadata": {
        "id": "lNBJisldczUh"
      },
      "execution_count": 29,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# backup dos modelos\n",
        "base_A = modelo_A()\n",
        "base_B = modelo_B()\n",
        "base_C = modelo_C()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "DlwzFtq7c2Ky",
        "outputId": "3ac9d359-e058-4e4a-ff2f-aebd4980c6b4"
      },
      "execution_count": 30,
      "outputs": [
        {
          "output_type": "stream",
